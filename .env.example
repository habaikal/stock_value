# StockValuationAI Pro - 환경 설정 완전 가이드
# 실제 사용할 때는 .env로 저장하고 값을 채우세요!

# ========== Gemini API 설정 (필수) ==========
# Google AI Studio에서 무료로 받을 수 있습니다
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=sk-proj-YOUR_API_KEY_HERE

# ========== 로깅 설정 ==========
LOG_LEVEL=INFO

# ========== 배포 환경 ==========
ENVIRONMENT=production

# ========== 성능 설정 ==========
PARALLEL_REQUESTS=5
TIMEOUT_SECONDS=30
RETRY_ATTEMPTS=3

# ========== 캐시 설정 ==========
CACHE_PRICE_HOURS=1
CACHE_FUNDAMENTALS_DAYS=7
CACHE_INDICATORS_HOURS=2

# ========== 포트폴리오 설정 ==========
PORTFOLIO_CASH_INIT=100000000
REBALANCE_INTERVAL=30

# ========== 추적 설정 ==========
TRACK_FOREIGNERS=true
TRACK_INSTITUTIONAL=true
FOREIGN_DAILY_THRESHOLD=5000000000

# ========== 개발자 설정 ==========
DEBUG_MODE=false
OPTIMIZE_MEMORY=false

# ========== 보안 ==========
RATE_LIMIT_REQUESTS=100
SESSION_TIMEOUT=60

# 로컬 사용: cp .env.example .env 후 값 수정
# 클라우드: Streamlit Cloud/Docker 환경 변수 설정
